#!/bin/bash
# 一键安装脚本 (install-ai-healing.sh)
# 使用方法: bash <(curl -s https://raw.githubusercontent.com/ai-healing/demo/main/install.sh)

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# 显示标题
echo -e "${BLUE}╔══════════════════════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║                    AI治愈伴侣 - 单服务器一键部署脚本                             ║${NC}"
echo -e "${BLUE}║                           版本: 2.0.0 | 自动部署系统                              ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════════════════════════════════════════════════╝${NC}"
echo ""

# 检查系统
check_system() {
    echo -e "${GREEN}[1/8] 检查系统环境...${NC}"
    
    # 检查是否为Linux
    if [[ "$OSTYPE" != "linux-gnu"* ]]; then
        echo -e "${RED}错误: 此脚本仅支持Linux系统${NC}"
        exit 1
    fi
    
    # 检查root权限
    if [[ $EUID -ne 0 ]]; then
        echo -e "${YELLOW}警告: 建议使用root权限运行此脚本${NC}"
        read -p "是否继续? (y/n): " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
    
    # 检查系统版本
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS=$NAME
        VER=$VERSION_ID
        echo -e "${GREEN}系统: $OS $VER${NC}"
    else
        echo -e "${YELLOW}警告: 无法确定系统版本${NC}"
    fi
    
    # 检查内存
    MEM_TOTAL=$(free -g | awk 'NR==2 {print $2}')
    if [ "$MEM_TOTAL" -lt 4 ]; then
        echo -e "${YELLOW}警告: 系统内存不足，建议至少4GB内存，当前: ${MEM_TOTAL}GB${NC}"
    fi
    
    # 检查磁盘空间
    DISK_SPACE=$(df -h . | awk 'NR==2 {print $4}' | sed 's/G//')
    if [ "${DISK_SPACE%%.*}" -lt 20 ]; then
        echo -e "${YELLOW}警告: 磁盘空间不足，建议至少20GB可用空间，当前: ${DISK_SPACE}GB${NC}"
    fi
}

# 安装Docker
install_docker() {
    echo -e "${GREEN}[2/8] 安装Docker和Docker Compose...${NC}"
    
    if command -v docker &> /dev/null; then
        echo -e "${GREEN}✓ Docker已安装${NC}"
    else
        echo -e "${YELLOW}安装Docker...${NC}"
        curl -fsSL https://get.docker.com -o get-docker.sh
        sh get-docker.sh
        rm get-docker.sh
        
        # 启动Docker
        systemctl start docker
        systemctl enable docker
        
        # 添加当前用户到docker组
        usermod -aG docker $USER
        
        echo -e "${GREEN}✓ Docker安装完成${NC}"
    fi
    
    if command -v docker-compose &> /dev/null; then
        echo -e "${GREEN}✓ Docker Compose已安装${NC}"
    else
        echo -e "${YELLOW}安装Docker Compose...${NC}"
        DOCKER_COMPOSE_VERSION=$(curl -s https://api.github.com/repos/docker/compose/releases/latest | grep '"tag_name"' | cut -d'"' -f4)
        curl -L "https://github.com/docker/compose/releases/download/$DOCKER_COMPOSE_VERSION/docker-compose-$(uname -s)-$(uname -m)" -o /usr/local/bin/docker-compose
        chmod +x /usr/local/bin/docker-compose
        
        # 创建软链接
        if [ ! -f /usr/bin/docker-compose ]; then
            ln -s /usr/local/bin/docker-compose /usr/bin/docker-compose
        fi
        
        echo -e "${GREEN}✓ Docker Compose安装完成${NC}"
    fi
}

# 下载部署包
download_package() {
    echo -e "${GREEN}[3/8] 下载部署包...${NC}"
    
    # 创建安装目录
    INSTALL_DIR="/opt/ai-healing"
    echo -e "${GREEN}安装目录: $INSTALL_DIR${NC}"
    
    if [ -d "$INSTALL_DIR" ]; then
        echo -e "${YELLOW}目录已存在，备份中...${NC}"
        BACKUP_DIR="${INSTALL_DIR}_backup_$(date +%Y%m%d_%H%M%S)"
        mv "$INSTALL_DIR" "$BACKUP_DIR"
        echo -e "${GREEN}已备份到: $BACKUP_DIR${NC}"
    fi
    
    mkdir -p "$INSTALL_DIR"
    cd "$INSTALL_DIR"
    
    # 下载部署包
    echo -e "${GREEN}下载部署包...${NC}"
    
    # 方法1: 从GitHub下载
    if command -v git &> /dev/null; then
        echo -e "${GREEN}使用Git克隆仓库...${NC}"
        git clone https://github.com/ai-healing/demo.git .
    else
        echo -e "${GREEN}使用curl下载...${NC}"
        curl -L https://github.com/ai-healing/demo/archive/refs/heads/main.zip -o ai-healing.zip
        unzip ai-healing.zip
        mv demo-main/* .
        mv demo-main/.* . 2>/dev/null || true
        rm -rf demo-main ai-healing.zip
    fi
    
    # 设置权限
    chmod -R 755 .
    chmod +x *.sh scripts/*.sh
    
    echo -e "${GREEN}✓ 部署包下载完成${NC}"
}

# 配置环境
configure_environment() {
    echo -e "${GREEN}[4/8] 配置环境变量...${NC}"
    
    cd "$INSTALL_DIR"
    
    # 生成随机密码
    generate_password() {
        openssl rand -base64 32 | tr -dc 'a-zA-Z0-9!@#$%^&*' | head -c 24
    }
    
    # 检查环境文件
    if [ ! -f ".env.local" ]; then
        if [ -f ".env.example" ]; then
            echo -e "${GREEN}创建环境配置文件...${NC}"
            cp .env.example .env.local
            
            # 生成随机密码
            MYSQL_ROOT_PASSWORD=$(generate_password)
            MYSQL_PASSWORD=$(generate_password)
            REDIS_PASSWORD=$(generate_password)
            JWT_SECRET=$(generate_password)
            JWT_REFRESH_SECRET=$(generate_password)
            GRAFANA_PASSWORD=$(generate_password)
            
            # 更新密码
            sed -i "s|^MYSQL_ROOT_PASSWORD=.*|MYSQL_ROOT_PASSWORD=$MYSQL_ROOT_PASSWORD|" .env.local
            sed -i "s|^MYSQL_PASSWORD=.*|MYSQL_PASSWORD=$MYSQL_PASSWORD|" .env.local
            sed -i "s|^REDIS_PASSWORD=.*|REDIS_PASSWORD=$REDIS_PASSWORD|" .env.local
            sed -i "s|^JWT_SECRET=.*|JWT_SECRET=$JWT_SECRET|" .env.local
            sed -i "s|^JWT_REFRESH_SECRET=.*|JWT_REFRESH_SECRET=$JWT_REFRESH_SECRET|" .env.local
            sed -i "s|^GRAFANA_PASSWORD=.*|GRAFANA_PASSWORD=$GRAFANA_PASSWORD|" .env.local
            
            # 获取本机IP
            IP_ADDR=$(hostname -I | awk '{print $1}')
            if [ -z "$IP_ADDR" ]; then
                IP_ADDR="localhost"
            fi
            
            echo -e "${GREEN}检测到服务器IP: $IP_ADDR${NC}"
            read -p "请输入访问域名或IP [默认: $IP_ADDR]: " DOMAIN_INPUT
            DOMAIN=${DOMAIN_INPUT:-$IP_ADDR}
            sed -i "s|^DOMAIN=.*|DOMAIN=$DOMAIN|" .env.local
            
            echo -e "${YELLOW}请设置OpenAI API密钥:${NC}"
            read -p "OpenAI API Key (必填): " OPENAI_API_KEY
            if [ -n "$OPENAI_API_KEY" ]; then
                sed -i "s|^OPENAI_API_KEY=.*|OPENAI_API_KEY=$OPENAI_API_KEY|" .env.local
            fi
            
            echo -e "${GREEN}✓ 环境配置完成${NC}"
            echo -e "${YELLOW}已生成随机密码，可在 .env.local 文件中查看${NC}"
        fi
    fi
    
    echo -e "${GREEN}环境变量配置完成${NC}"
}

# 安装Docker镜像
pull_images() {
    echo -e "${GREEN}[5/8] 拉取Docker镜像...${NC}"
    
    cd "$INSTALL_DIR"
    
    echo -e "${GREEN}拉取基础镜像...${NC}"
    
    # 拉取所有镜像
    docker-compose pull || {
        echo -e "${YELLOW}Docker Compose拉取失败，尝试直接拉取...${NC}"
        
        # 如果docker-compose pull失败，尝试分别拉取
        IMAGES=(
            "mysql:8.0.33"
            "redis:7.0.11-alpine"
            "traefik:v2.9"
            "prom/prometheus:v2.43.0"
            "grafana/grafana:9.5.2"
            "adminer:4.8.1"
            "rediscommander/redis-commander:latest"
            "alpine:3.17"
        )
        
        for image in "${IMAGES[@]}"; do
            echo -e "${GREEN}拉取 $image ...${NC}"
            docker pull $image
        done
    }
    
    echo -e "${GREEN}✓ 镜像拉取完成${NC}"
}

# 启动服务
start_services() {
    echo -e "${GREEN}[6/8] 启动所有服务...${NC}"
    
    cd "$INSTALL_DIR"
    
    echo -e "${GREEN}启动Docker Compose服务...${NC}"
    
    # 创建必要的目录
    mkdir -p data/mysql data/redis data/prometheus data/grafana
    mkdir -p logs/backend logs/frontend logs/nginx logs/mysql logs/redis
    mkdir -p backup scripts
    
    # 启动服务
    docker-compose up -d
    
    # 等待服务启动
    echo -e "${GREEN}等待服务启动...${NC}"
    sleep 10
    
    # 检查服务状态
    echo -e "${GREEN}检查服务状态...${NC}"
    docker-compose ps
    
    echo -e "${GREEN}✓ 服务启动完成${NC}"
}

# 初始化数据库
init_database() {
    echo -e "${GREEN}[7/8] 初始化数据库...${NC}"
    
    cd "$INSTALL_DIR"
    
    echo -e "${GREEN}等待MySQL启动...${NC}"
    
    # 等待MySQL启动
    for i in {1..30}; do
        if docker-compose exec -T mysql mysqladmin ping -u root -p"$MYSQL_ROOT_PASSWORD" --silent 2>/dev/null; then
            echo -e "${GREEN}✓ MySQL已启动${NC}"
            break
        fi
        echo -n "."
        sleep 2
    done
    
    # 运行数据库初始化脚本
    if [ -f "./scripts/init/init-db.sh" ]; then
        echo -e "${GREEN}运行数据库初始化脚本...${NC}"
        chmod +x ./scripts/init/init-db.sh
        ./scripts/init/init-db.sh
    else
        echo -e "${YELLOW}数据库初始化脚本不存在，跳过${NC}"
    fi
    
    echo -e "${GREEN}✓ 数据库初始化完成${NC}"
}

